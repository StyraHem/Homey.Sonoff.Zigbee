      "image": "/drivers/ZBMINI/assets/images/large.png",
      "instruction": {
        "en": "Press the button on the device for 5 seconds until the LED blinks rapidly to enter pairing mode.",
        "es": "Mantén pulsado el botón del dispositivo durante 5 segundos hasta que el LED parpadee rápidamente para entrar en modo de emparejamiento."
      }
    }
  },
