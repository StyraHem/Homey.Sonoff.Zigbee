    "nl": "MINI-ZBDIM Dimmer",
    "de": "MINI-ZBDIM Dimmer",
    "fr": "Variateur MINI-ZBDIM",
    "it": "Dimmer MINI-ZBDIM",
    "no": "MINI-ZBDIM Dimmer",
    "sv": "MINI-ZBDIM Dimmer",
